# DGM — Darwin Gödel Machine
# Environment configuration — copy to .env and fill in values

# ── Sovereign Core (primary inference) ───────────────────────────────────────
# URL of your Sovereign Core gateway (TatorTot or localhost)
SOVEREIGN_GATEWAY_URL=http://localhost:8000

# Primary brain model (for proposer, critic, meta-agent)
SOVEREIGN_PRIMARY_MODEL=qwen2.5:14b

# Code verification model (for verifier agent — DeepSeek-Coder on Radeon)
SOVEREIGN_CODER_MODEL=deepseek-coder:6.7b

# Request timeout in seconds
SOVEREIGN_TIMEOUT=120

# Max tokens per response
SOVEREIGN_MAX_TOKENS=16384

# ── Direct Ollama fallback ────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Cloud fallbacks (used only if all local inference fails) ──────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o)
OPENAI_API_KEY=

# ── DGM evaluation ────────────────────────────────────────────────────────────
# SWE-bench evaluation mode
EVAL_MODE=local

# Number of parallel self-improvement threads
SELFIMPROVE_WORKERS=2

# Output directory for DGM runs
DGM_OUTPUT_DIR=./output

# ── Docker (for sandbox evaluation) ──────────────────────────────────────────
DOCKER_ENABLED=true
