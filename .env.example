# Sovereign Core — DGM environment config
# Copy to .env and adjust for your setup.

# Endpoint served by vLLM on TatorTot (or localhost for same-machine)
SOVEREIGN_API_BASE=http://localhost:8001/v1

# Model identifier (must match what vLLM is serving)
SOVEREIGN_MODEL=qwen2.5-32b-awq

# API key — vLLM ignores this but the OpenAI SDK requires a non-empty value
SOVEREIGN_API_KEY=sovereign
